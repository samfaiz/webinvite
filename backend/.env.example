# ---- Backend (NestJS) environment ----
# Copy to .env and fill in real values. NEVER commit the real .env.

# SQLite. The path is resolved relative to the prisma/ folder, so "file:./dev.db"
# means prisma/dev.db. (Docker overrides this to file:/data/prod.db on a volume.)
# It MUST start with file:  —  a bare path will fail with Prisma error P1012.
DATABASE_URL="file:./dev.db"

# API listen port (nginx proxies to this)
PORT=4000

# Public site origin — used for CORS and for building absolute upload URLs.
FRONTEND_ORIGIN="https://your-domain.com"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Master key for encrypting admin-managed secrets (API keys, GA service account)
# at rest with AES-256-GCM. Use a long random string. If unset, a key is derived
# from JWT_SECRET (works, but then don't rotate JWT_SECRET or you'll orphan
# saved secrets). Generate: `openssl rand -base64 48`
SECRETS_KEY="change-me-to-a-long-random-string"

# Default "from" identity if the admin hasn't configured email in the panel.
MAIL_FROM="Eternal <no-reply@your-domain.com>"

# Optional SMTP fallback (the admin can also set these in Admin → Email settings)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---- AI (Claude) — powers AI SEO suggestions, the weekly SEO audit and blog
# drafting. PREFERRED: set the key in Admin → Integrations (stored encrypted in
# the DB). These env vars are an optional fallback. Without either, AI features
# are disabled gracefully; everything else works unchanged.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"   # or claude-haiku-4-5-20251001 (cheaper) / claude-opus-4-8 (best)
# SEO_AUDIT_CRON="on"                     # set to "off" to disable the weekly Monday 03:00 audit

# ---- Analytics ----
# Built-in analytics need no config (first-party, privacy-friendly, always on).
# Optional: pull Google Analytics 4 stats into the admin dashboard. PREFERRED:
# set the Measurement ID, Property ID and service-account JSON in Admin →
# Integrations (service account stored encrypted). These env vars are a fallback.
# Create a GA4 property, then a Google Cloud service account with the Analytics
# Data API and read access to the property.
# GA4_MEASUREMENT_ID="G-XXXXXXXXXX"   # tracking tag (served to the frontend via /public/config)
# GA4_PROPERTY_ID="123456789"
# GA_SERVICE_ACCOUNT_JSON='{"type":"service_account","private_key":"-----BEGIN PRIVATE KEY-----\n...\n","client_email":"...@....iam.gserviceaccount.com"}'
