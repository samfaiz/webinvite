# ---- Backend (NestJS) environment ----
# Copy to .env and fill in real values. NEVER commit the real .env.

# SQLite. The path is resolved relative to the prisma/ folder, so "file:./dev.db"
# means prisma/dev.db. (Docker overrides this to file:/data/prod.db on a volume.)
# It MUST start with file:  —  a bare path will fail with Prisma error P1012.
DATABASE_URL="file:./dev.db"

# API listen port (nginx proxies to this)
PORT=4000

# Public site origin — used for CORS and for building absolute upload URLs.
FRONTEND_ORIGIN="https://your-domain.com"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Default "from" identity if the admin hasn't configured email in the panel.
MAIL_FROM="Eternal <no-reply@your-domain.com>"

# Optional SMTP fallback (the admin can also set these in Admin → Email settings)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---- AI (Claude) — powers AI SEO suggestions, the weekly SEO audit and blog
# drafting. Without ANTHROPIC_API_KEY these features are disabled gracefully
# (the admin UI shows "AI not configured"); everything else works unchanged.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"   # or claude-haiku-4-5-20251001 (cheaper) / claude-opus-4-8 (best)
# SEO_AUDIT_CRON="on"                     # set to "off" to disable the weekly Monday 03:00 audit

# ---- Analytics ----
# Built-in analytics need no config (first-party, privacy-friendly, always on).
# Optional: pull Google Analytics 4 stats into the admin dashboard. Create a GA4
# property, then a Google Cloud service account with the Analytics Data API and
# read access to the property. GA_SERVICE_ACCOUNT_JSON is the service-account
# key file's full JSON on one line.
# GA4_PROPERTY_ID="123456789"
# GA_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'
# (Frontend, for the GA4 tracking tag: set NEXT_PUBLIC_GA4_ID in the frontend env.)
