// Wedding-invitation SaaS data model.
//
// DEV uses SQLite (zero install). For PRODUCTION switch to PostgreSQL:
//   1. change provider below to "postgresql"
//   2. set DATABASE_URL to your Postgres connection string (e.g. Neon)
//   3. delete prisma/migrations (SQLite-specific) and run `npx prisma migrate dev`
// Content/theme are stored as JSON strings so the schema is identical on both.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  role         String       @default("user") // "user" | "admin"
  /// admin-granted: may duplicate their own invitations (off by default)
  canDuplicate Boolean      @default(false)
  createdAt    DateTime     @default(now())
  invitations  Invitation[]
}

model Invitation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String?   @unique // null for drafts; set on publish
  templateId  String
  themeId     String
  motifId     String
  themeJson   String // custom Theme object as JSON
  contentJson String // InvitationContent as JSON
  status      String    @default("draft") // "draft" | "published" | "expired"
  eventDate   DateTime?
  expiryDate  DateTime?
  ownerEmail  String?
  views       Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  rsvps       Rsvp[]

  @@index([userId])
}

model Design {
  id             String   @id @default(cuid())
  name           String
  community      String // motif community key
  templateId     String // base layout
  colorsJson     String // Theme.colors JSON
  fontsJson      String // Theme.fonts JSON
  particlesJson  String // Theme.particles JSON
  backgroundsJson String // { hero?, families?, story?, schedule?, rsvp?, all? } image URLs
  previewUrl     String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([community])
}

model Rsvp {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guestName    String
  attending    String // "accept" | "decline"
  guests       Int        @default(1)
  message      String?
  /// guest's email (optional) — used for the confirmation email and updates
  email        String?
  /// consented to receive wedding updates at `email`
  subscribed   Boolean    @default(false)
  /// when the confirmation email was actually delivered to SMTP — dedupe
  /// counts only these, so failed sends (e.g. broken SMTP) can be retried
  confirmedAt  DateTime?
  createdAt    DateTime   @default(now())

  @@index([invitationId])
}

/// Admin-configurable app settings, stored as a flat key→value map.
/// Mail keys: mail.fromName, mail.fromEmail, mail.smtpHost, mail.smtpPort,
/// mail.smtpUser, mail.smtpPass, mail.enabled.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// CMS content — marketing pages ("page") and blog posts ("post"). Body is a
/// list of editor blocks stored as JSON; per-doc SEO fields feed the page's
/// <head>. One row serves both types so the block editor/renderer are shared.
///
/// For "page" docs the admin form ALSO exposes: sortOrder (nav position),
/// canonicalUrl (SEO), faqsJson (answer-engine optimisation Q&A list). The
/// tagsJson column doubles as SEO keywords on pages.
model ContentDoc {
  id             String    @id @default(cuid())
  type           String // "page" | "post"
  slug           String
  title          String
  excerpt        String? // short summary (blog cards, meta fallback)
  coverImage     String? // hero/cover image URL
  blocksJson     String    @default("[]") // Block[] as JSON
  tagsJson       String    @default("[]") // string[] (SEO keywords for pages)
  authorName     String?
  status         String    @default("draft") // "draft" | "published"
  seoTitle       String?
  seoDescription String?
  ogTitle        String? // Social (OG) title — falls back to seoTitle
  ogDescription  String? // Social (OG) description — falls back to seoDescription
  ogImage        String?
  canonicalUrl   String? // absolute URL; blank = the page's own URL
  faqsJson       String    @default("[]") // [{id, question, answer}] for AEO
  sortOrder      Int       @default(0) // ascending; nav / list ordering
  noindex        Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  seoProposals SeoProposal[]
  seoMemory    SeoMemory?

  @@unique([type, slug])
  @@index([type, status])
  @@index([type, sortOrder])
}

/// AI-generated SEO suggestion for a ContentDoc, awaiting admin review.
/// Approving applies the proposed fields to the doc and appends to its memory.
model SeoProposal {
  id             String     @id @default(cuid())
  contentId      String
  content        ContentDoc @relation(fields: [contentId], references: [id], onDelete: Cascade)
  status         String     @default("pending") // pending | applied | rejected
  source         String     @default("audit") // audit | manual
  score          Int? // 0-100 SEO score at audit time
  seoTitle       String?
  seoDescription String?
  issuesJson     String     @default("[]") // detected issues (string[])
  rationale      String?
  createdAt      DateTime   @default(now())
  reviewedAt     DateTime?

  @@index([status])
  @@index([contentId])
}

/// Per-page SEO memory: an append-only history of decisions the AI reads before
/// proposing, and writes to when a proposal is approved.
model SeoMemory {
  contentId String     @id
  content   ContentDoc @relation(fields: [contentId], references: [id], onDelete: Cascade)
  notesJson String     @default("[]") // [{ at, note, source }]
  updatedAt DateTime   @updatedAt
}

/// Curated background-music library. Couples pick a track for their invitation;
/// admins manage the list (upload/host the audio and set title + mood).
model Track {
  id        String   @id @default(cuid())
  title     String
  mood      String? // e.g. "Romantic", "Acoustic", "Cinematic"
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Messages submitted through the public /contact form. The admin inbox shows
/// them, marks them read/replied, and can delete. Kept intentionally simple —
/// no attachments, no threading; treat as first-touch capture.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("new") // "new" | "read" | "replied"
  source    String   @default("contact-page") // where it came from
  ip        String? // reduced to /24 or /48 for privacy; can be null
  userAgent String?
  createdAt DateTime @default(now())
  readAt    DateTime?
  repliedAt DateTime?

  @@index([status, createdAt])
}

/// Singleton config for the SEO/AEO/GEO audit algorithm. The prompt/rubric
/// itself + the "AI learning memory" live in `SeoAlgorithmVersion` (each save
/// creates a new version); this row only holds the auto-improve toggles.
model SeoAlgorithm {
  id             String    @id
  autoImprove    Boolean   @default(false)
  frequency      String    @default("weekly") // "daily" | "weekly" | "monthly"
  versionsToKeep Int       @default(90)
  lastRunAt      DateTime?
  lastRunNote    String?
  updatedAt      DateTime  @updatedAt
}

/// One archived revision of the SEO algorithm. Each admin save + AI improve
/// run inserts a new row (marked isCurrent = true) so the admin can compare
/// and revert. Older rows past `SeoAlgorithm.versionsToKeep` are pruned.
model SeoAlgorithmVersion {
  id             String   @id @default(cuid())
  algorithm      String   // the prompt / rubric text
  learningMemory String   // the AI learning-memory notes at time of save
  avgAuditScore  Float?   // updated when downstream audits complete
  source         String   @default("manual") // manual | ai-improve | schedule | restore | reset
  isCurrent      Boolean  @default(false) // exactly one row has this true
  createdAt      DateTime @default(now())

  @@index([isCurrent])
  @@index([createdAt])
}

/// Privacy-friendly, first-party pageview log for the built-in analytics
/// dashboard. `visitor` is an anonymous daily-rotating hash of IP+UA (no raw IP
/// or PII is stored, no cookies). Referrer is reduced to a host label.
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String? // source host, or null for direct
  device    String? // "mobile" | "tablet" | "desktop"
  visitor   String // anonymous hash for unique-visitor counts
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}
